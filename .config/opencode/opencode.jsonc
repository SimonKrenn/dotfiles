{
	"$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "plugin": ["opencode-pty"],
	"mcp": {
		"playwright": { 
      "enabled": true,
			"type": "local",
			"command": [
				"npx",
				"@playwright/mcp@latest"
			]
		},
		"figma-dev-mode": {
			"enabled": false,
			"type": "remote",
			"url": "http://127.0.0.1:3845/mcp"
		},
		"atlassian-mcp": {
			"enabled": false,
			"type": "local",
			"command": [
				"npx",
				"-y",
				"mcp-remote",
				"https://mcp.atlassian.com/v1/sse",
        "--debug"
			]
		},
    "chrome-devtools" : {
      "enabled" : true,
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest"]
    },
    "exa-search" : {
      "enabled" : true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"  
    },
   "fff": {
      "type": "local",
      "command": [
        "fff-mcp"
      ],
      "enabled": true
    },
	}
}
